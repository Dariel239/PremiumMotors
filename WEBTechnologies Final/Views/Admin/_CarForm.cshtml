@* _CarForm — the shared set of form fields for creating AND editing a car, factored into a
   partial so Create.cshtml and Edit.cshtml don't duplicate it (DRY). The surrounding <form>
   tag (with its action and enctype="multipart/form-data" for file upload) lives in the caller.
   Model is the Car being created/edited. *@
@model Car

@* Shows model-level validation errors (field errors appear next to each field). *@
<div asp-validation-summary="ModelOnly" class="text-danger"></div>
@* Hidden Id so edits post back which car they belong to (0/empty for a new car). *@
<input type="hidden" asp-for="Id" />

<div class="row g-3">
    <div class="col-md-6">
        @* asp-for wires label text, the input's name/value, and validation to Model.Make. *@
        <label asp-for="Make" class="form-label"></label>
        <input asp-for="Make" class="form-control" placeholder="e.g. Mercedes-Benz" />
        <span asp-validation-for="Make" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Model" class="form-label"></label>
        <input asp-for="Model" class="form-control" placeholder="e.g. C-Class" />
        <span asp-validation-for="Model" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        @* Html.GetEnumSelectList<CarType>() generates the <option>s from the CarType enum
           (using the [Display] names), and asp-for selects the car's current type. *@
        <label asp-for="Type" class="form-label"></label>
        <select asp-for="Type" class="form-select" asp-items="Html.GetEnumSelectList<CarType>()"></select>
        <span asp-validation-for="Type" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Year" class="form-label"></label>
        <input asp-for="Year" class="form-control" type="number" min="1900" max="2100" />
        <span asp-validation-for="Year" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        @* The € prefix is a static label; the bound value is just the number. *@
        <label asp-for="StartingPrice" class="form-label"></label>
        <div class="input-group">
            <span class="input-group-text">€</span>
            <input asp-for="StartingPrice" class="form-control" type="number" step="0.01" min="0" />
        </div>
        <span asp-validation-for="StartingPrice" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        @* Optional instant-buy price (the model property is a nullable decimal). *@
        <label asp-for="InstantBuyPrice" class="form-label"></label>
        <div class="input-group">
            <span class="input-group-text">€</span>
            <input asp-for="InstantBuyPrice" class="form-control" type="number" step="0.01" min="0" placeholder="Optional" />
        </div>
        <div class="form-text">Leave blank for auction-only (no instant buy).</div>
        <span asp-validation-for="InstantBuyPrice" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        @* AuctionEnd is entered as text in dd/MM/yyyy HH:mm; value pre-formats the existing
           date when editing. (Free-text dates rely on model binding to parse them.) *@
        <label asp-for="AuctionEnd" class="form-label"></label>
        <input asp-for="AuctionEnd" class="form-control" type="text" autocomplete="off"
               placeholder="dd/mm/yyyy hh:mm"
               value="@(Model.AuctionEnd?.ToString("dd/MM/yyyy HH:mm"))" />
        <div class="form-text">Optional. Format: <strong>dd/mm/yyyy hh:mm</strong> (e.g. 25/12/2026 14:30). Leave blank for an open-ended auction.</div>
        <span asp-validation-for="AuctionEnd" class="text-danger"></span>
    </div>

    <div class="col-12">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="5"
                  placeholder="Condition, history, options, mileage..."></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="col-12">
        @* File input for photos. name="photos" matches the List<IFormFile> parameter on the
           controller actions; "multiple" allows several files; accept="image/*" hints the
           browser to show only image files. *@
        <label class="form-label">Photos</label>
        <input type="file" name="photos" class="form-control" accept="image/*" multiple />
        <div class="form-text">You can select multiple images.</div>

        @* When editing, show thumbnails of the existing photos. *@
        @if (Model.ImagePaths.Count > 0)
        {
            <div class="d-flex flex-wrap gap-2 mt-2">
                @foreach (var img in Model.ImagePaths)
                {
                    <img src="@img" class="rounded border" style="height:64px;width:auto" alt="current photo" />
                }
            </div>
            @* Reminder of the replace-on-upload behaviour (see AdminController.Edit). *@
            <div class="form-text">Uploading new photos will replace the ones above.</div>
        }
    </div>
</div>

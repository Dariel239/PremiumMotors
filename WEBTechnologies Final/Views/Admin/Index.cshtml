@* Admin/Index — the admin dashboard: summary stat cards plus a management table of every
   listing. Model is the list of cars; the stats came separately via ViewData["Stats"]. *@
@model IReadOnlyList<Car>
@{
    ViewData["Title"] = "Manage Listings";
    @* Cast the stats object out of ViewData (it was boxed as object). *@
    var stats = ViewData["Stats"] as WEBTechnologies_Final.Services.CarStats;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Manage Listings</h1>
    <a asp-action="Create" class="btn btn-success">+ Post a Car</a>
</div>

@* ---------- Stat cards (only if stats were supplied) ---------- *@
@if (stats is not null)
{
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card text-center shadow-sm">
                <div class="card-body py-3">
                    <div class="fs-2 fw-bold text-primary">@stats.Total</div>
                    <div class="small text-muted">Total Listings</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center shadow-sm">
                <div class="card-body py-3">
                    <div class="fs-2 fw-bold text-success">@stats.Active</div>
                    <div class="small text-muted">Active Auctions</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center shadow-sm">
                <div class="card-body py-3">
                    <div class="fs-2 fw-bold text-danger">@stats.Sold</div>
                    <div class="small text-muted">Sold</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center shadow-sm">
                <div class="card-body py-3">
                    <div class="fs-2 fw-bold text-warning">@stats.TotalBids</div>
                    <div class="small text-muted">Total Bids</div>
                </div>
            </div>
        </div>
    </div>
}

@* ---------- Listings table ---------- *@
@if (Model.Count == 0)
{
    <div class="alert alert-info">No listings yet. Click "Post a Car" to add one.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th></th>
                    <th>Car</th>
                    <th>Type</th>
                    <th>Year</th>
                    <th>Current price</th>
                    <th>Instant buy</th>
                    <th>Bids</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @* One row per car. *@
                @foreach (var car in Model)
                {
                    <tr>
                        <td>
                            <img src="@car.PrimaryImage" alt="@car.Title"
                                 style="height:42px;width:64px;object-fit:cover" class="rounded" />
                        </td>
                        <td>
                            <a asp-controller="Cars" asp-action="Details" asp-route-id="@car.Id"
                               class="text-decoration-none fw-semibold">@car.Make @car.Model</a>
                        </td>
                        <td>@car.Type</td>
                        <td>@car.Year</td>
                        <td>@car.CurrentPrice.ToString("C")</td>
                        @* Show the instant-buy price, or an em-dash when none is set. *@
                        <td>@(car.InstantBuyPrice?.ToString("C") ?? "—")</td>
                        <td>@car.Bids.Count</td>
                        <td>
                            @if (car.IsClosed)
                            {
                                <span class="badge bg-danger">Closed</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Live</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@car.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                            @* "Close" is offered only for still-live auctions; it's a POST form
                               (state change) with a JS confirm() guard. *@
                            @if (!car.IsClosed)
                            {
                                <form asp-action="Close" asp-route-id="@car.Id" method="post" class="d-inline"
                                      onsubmit="return confirm('Close this auction now?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-warning">Close</button>
                                </form>
                            }
                            @* Delete links to the confirmation page (the actual delete is a POST there). *@
                            <a asp-action="Delete" asp-route-id="@car.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

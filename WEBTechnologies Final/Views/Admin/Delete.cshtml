@* Admin/Delete — a confirmation page shown before actually deleting a listing. Following the
   safe pattern, the GET only displays details; the destructive delete happens via the POST
   form below (handled by AdminController.DeleteConfirmed). Model is the car to be removed. *@
@model Car
@{
    ViewData["Title"] = "Delete " + Model.Title;
}

<h1 class="h3 mb-3 text-danger">Delete Listing</h1>

<div class="card shadow-sm">
    <div class="row g-0">
        <div class="col-md-4">
            <img src="@Model.PrimaryImage" class="img-fluid rounded-start h-100" style="object-fit:cover" alt="@Model.Title" />
        </div>
        <div class="col-md-8">
            <div class="card-body">
                @* Show what will be deleted so the admin can confirm it's the right car. *@
                <p>Are you sure you want to permanently delete this listing?</p>
                <h2 class="h5">@Model.Title</h2>
                <dl class="row small text-muted">
                    <dt class="col-4">Type</dt><dd class="col-8">@Model.Type</dd>
                    <dt class="col-4">Current price</dt><dd class="col-8">@Model.CurrentPrice.ToString("C")</dd>
                    <dt class="col-4">Bids</dt><dd class="col-8">@Model.Bids.Count</dd>
                </dl>

                @* POST to confirm. The car's bids are removed automatically by the cascade
                   delete configured in AppDbContext. *@
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">Yes, delete</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>

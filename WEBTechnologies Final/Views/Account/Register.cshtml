@* The account-creation form, bound to RegisterViewModel. The validation attributes on that
   model (username length, valid email, password length, ConfirmPassword match) drive both the
   labels and the client/server validation shown here. *@
@model RegisterViewModel
@{
    ViewData["Title"] = "Create Account";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card shadow-sm mt-4">
            <div class="card-body">
                <h1 class="h4 mb-3">Create an Account</h1>

                @* "ModelOnly" shows only model-level errors here (e.g. the controller's
                   "username already taken" message); per-field errors render next to each
                   field below via asp-validation-for. *@
                <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

                <form asp-action="Register" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="Username" class="form-label"></label>
                        <input asp-for="Username" class="form-control" autofocus />
                        <span asp-validation-for="Username" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Password" class="form-label"></label>
                        <input asp-for="Password" class="form-control" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        @* The [Compare] attribute on the model makes this field validate against
                           Password, so a mismatch is reported here automatically. *@
                        <label asp-for="ConfirmPassword" class="form-label"></label>
                        <input asp-for="ConfirmPassword" class="form-control" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>
                    <button type="submit" class="btn btn-success w-100">Register</button>
                </form>

                <p class="text-center mt-3 mb-0">
                    Already have an account? <a asp-action="Login">Log in</a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

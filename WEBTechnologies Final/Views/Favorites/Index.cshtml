@* Favorites/Index — the current user's saved cars as a grid of cards. The model is the list
   of favourited Car objects the FavoritesController loaded (already newest-first). *@
@model IReadOnlyList<Car>
@{
    ViewData["Title"] = "My Favourites";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-0">♥ My Favourites</h1>
        <p class="text-muted mb-0">@Model.Count saved listing(s)</p>
    </div>
    <a asp-controller="Cars" asp-action="Index" class="btn btn-outline-primary">Browse auctions</a>
</div>

@* Empty state with a hint on how to add favourites. *@
@if (Model.Count == 0)
{
    <div class="alert alert-info">
        You haven't saved any listings yet. Tap <strong>♡ Favourite</strong> on any car to add it here.
    </div>
}
else
{
    @* One card per saved car (same card style as the catalogue). *@
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
        @foreach (var car in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm car-card">
                    <a asp-controller="Cars" asp-action="Details" asp-route-id="@car.Id">
                        <img src="@car.PrimaryImage" class="card-img-top car-thumb" alt="@car.Title" />
                    </a>
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start">
                            <h3 class="h6 mb-1">
                                <a asp-controller="Cars" asp-action="Details" asp-route-id="@car.Id"
                                   class="text-dark text-decoration-none">@car.Title</a>
                            </h3>
                            <span class="badge bg-secondary">@car.Type</span>
                        </div>
                        <div class="mt-auto">
                            <div class="d-flex justify-content-between align-items-end mb-2">
                                <div>
                                    <div class="small text-muted">Current bid</div>
                                    <div class="fw-bold text-primary">@car.CurrentPrice.ToString("C")</div>
                                </div>
                                @if (car.IsClosed)
                                {
                                    <span class="badge bg-danger">Closed</span>
                                }
                            </div>
                            @* The favourite button here lets the user un-favourite (which would
                               remove the card on the next load). *@
                            <partial name="_FavoriteButton" model="car" view-data='new ViewDataDictionary(ViewData) { ["FavBtnClass"] = "btn-sm w-100" }' />
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

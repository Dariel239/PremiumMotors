@* Cars/Index — the public catalogue and the app's home page. Bound to CarListViewModel,
   which carries the filtered cars, the current filter values, and the dropdown option lists.
   Layout: a left filter sidebar and a right grid of car cards. *@
@model CarListViewModel
@{
    ViewData["Title"] = "Browse Auctions";
}

<div class="d-flex justify-content-between align-items-center flex-wrap mb-3">
    <div>
        <h1 class="h3 mb-0">Live Car Auctions</h1>
        @* Result count straight off the model. *@
        <p class="text-muted mb-0">@Model.Cars.Count car(s) found</p>
    </div>
</div>

<div class="row g-4">

    @* ---------- Filter sidebar ---------- *@
    @* method="get" so the filters become query-string parameters (e.g. ?search=&type=...),
       which CarsController.Index reads back. GET keeps the search shareable/bookmarkable. *@
    <div class="col-lg-3">
        <form asp-action="Index" method="get" class="card shadow-sm">
            <div class="card-body">
                <h2 class="h6 text-uppercase text-muted">Search &amp; Filter</h2>

                <div class="mb-3">
                    @* value="@Model.Search" repopulates the box so the search term sticks. *@
                    <label class="form-label" for="search">Search</label>
                    <input type="text" id="search" name="search" value="@Model.Search"
                           class="form-control" placeholder="Make, model, keyword..." />
                </div>

                <div class="mb-3">
                    @* asp-items binds the <option> list from the SelectList the controller
                       built (which also remembers the current selection). The extra static
                       <option value=""> provides the "Any" / no-filter choice. *@
                    <label class="form-label" for="type">Type</label>
                    <select id="type" name="type" class="form-select" asp-items="Model.TypeOptions">
                        <option value="">Any type</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="make">Make</label>
                    <select id="make" name="make" class="form-select" asp-items="Model.MakeOptions">
                        <option value="">Any make</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="model">Model</label>
                    <select id="model" name="model" class="form-select" asp-items="Model.ModelOptions">
                        <option value="">Any model</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="year">Model Year</label>
                    <select id="year" name="year" class="form-select" asp-items="Model.YearOptions">
                        <option value="">Any year</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="sortBy">Sort by</label>
                    <select id="sortBy" name="sortBy" class="form-select" asp-items="Model.SortOptions"></select>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary">Apply</button>
                    @* Only offer "Clear filters" when at least one filter is active
                       (HasActiveFilters on the view model). It links to the unfiltered Index. *@
                    @if (Model.HasActiveFilters)
                    {
                        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Clear filters</a>
                    }
                </div>
            </div>
        </form>
    </div>

    @* ---------- Results grid ---------- *@
    <div class="col-lg-9">
        @* Friendly empty state when nothing matches the filters. *@
        @if (Model.Cars.Count == 0)
        {
            <div class="alert alert-info">
                No cars match your search. Try clearing some filters.
            </div>
        }
        else
        {
            <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
                @* Render one Bootstrap card per car. *@
                @foreach (var car in Model.Cars)
                {
                    <div class="col">
                        <div class="card h-100 shadow-sm car-card">
                            @* The photo links to the details page. car.PrimaryImage falls back
                               to a placeholder when the car has no images (see Car.cs). *@
                            <a asp-action="Details" asp-route-id="@car.Id" class="text-decoration-none">
                                <img src="@car.PrimaryImage" class="card-img-top car-thumb" alt="@car.Title" />
                            </a>
                            <div class="card-body d-flex flex-column">
                                <div class="d-flex justify-content-between align-items-start">
                                    <h3 class="h6 mb-1">
                                        <a asp-action="Details" asp-route-id="@car.Id"
                                           class="text-dark text-decoration-none">@car.Title</a>
                                    </h3>
                                    <span class="badge bg-secondary">@car.Type</span>
                                </div>
                                <p class="text-muted small mb-2 text-truncate">@car.Description</p>

                                @* mt-auto pushes this price/actions block to the bottom so all
                                   cards line up regardless of description length. *@
                                <div class="mt-auto">
                                    <div class="d-flex justify-content-between align-items-end mb-2">
                                        <div>
                                            @* Computed current price, formatted as euro currency. *@
                                            <div class="small text-muted">Current bid</div>
                                            <div class="fw-bold text-primary">@car.CurrentPrice.ToString("C")</div>
                                        </div>
                                        @* Show a "Closed" badge, otherwise the buy-now price if
                                           one is offered. "!" asserts InstantBuyPrice is non-null
                                           inside the HasInstantBuy branch. *@
                                        @if (car.IsClosed)
                                        {
                                            <span class="badge bg-danger">Closed</span>
                                        }
                                        else if (car.HasInstantBuy)
                                        {
                                            <div class="text-end">
                                                <div class="small text-muted">Buy now</div>
                                                <div class="fw-semibold text-success">@car.InstantBuyPrice!.Value.ToString("C")</div>
                                            </div>
                                        }
                                    </div>
                                    <div class="d-flex gap-2">
                                        <a asp-action="Details" asp-route-id="@car.Id" class="btn btn-sm btn-primary flex-grow-1">View</a>
                                        @* Reuse the favourite button partial for this card.
                                           A NEW ViewDataDictionary is passed so we can add a
                                           "FavBtnClass" hint (small button) without polluting the
                                           page's own ViewData. *@
                                        <partial name="_FavoriteButton" model="car" view-data='new ViewDataDictionary(ViewData) { ["FavBtnClass"] = "btn-sm" }' />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

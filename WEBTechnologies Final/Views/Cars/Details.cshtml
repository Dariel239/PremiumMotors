@* Cars/Details — a single listing: photo gallery, specs, the bid/buy panel, and bid history.
   Model is one Car (with its Bids eager-loaded by the controller). *@
@model Car
@{
    ViewData["Title"] = Model.Title;
    @* The minimum acceptable next bid: €100 over the current price. "100m" is a decimal literal. *@
    var minNextBid = Model.CurrentPrice + 100m;
    @* Current user from session (null when not logged in) — controls the bid panel below. *@
    var currentUser = Context.Session.GetString(SessionKeys.Username);
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Auctions</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Model.Title</li>
    </ol>
</nav>

<div class="row g-4">

    @* ---------- Left column: photo gallery + description ---------- *@
    <div class="col-lg-7">
        @{
            @* Use the uploaded images, or a single-item list with the placeholder if none. *@
            var images = Model.ImagePaths.Count > 0 ? Model.ImagePaths : new List<string> { Model.PrimaryImage };
        }
        <div id="carGallery" class="carousel slide shadow-sm rounded overflow-hidden" data-bs-ride="false">
            <div class="carousel-inner">
                @* A classic C# for-loop so we can mark the FIRST slide "active" (Bootstrap
                   requires exactly one active carousel item). *@
                @for (var i = 0; i < images.Count; i++)
                {
                    <div class="carousel-item @(i == 0 ? "active" : "")">
                        <img src="@images[i]" class="d-block w-100 detail-img" alt="@Model.Title" />
                    </div>
                }
            </div>
            @* Only render the prev/next controls when there is more than one image. *@
            @if (images.Count > 1)
            {
                <button class="carousel-control-prev" type="button" data-bs-target="#carGallery" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon"></span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#carGallery" data-bs-slide="next">
                    <span class="carousel-control-next-icon"></span>
                </button>
            }
        </div>

        <div class="card mt-4 shadow-sm">
            <div class="card-body">
                <h2 class="h5">Description</h2>
                @* white-space: pre-line preserves the line breaks the seller typed. *@
                <p class="mb-0" style="white-space: pre-line">@Model.Description</p>
            </div>
        </div>
    </div>

    @* ---------- Right column: specs, bidding/buying, bid history ---------- *@
    <div class="col-lg-5">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <h1 class="h4">@Model.Title</h1>
                    <span class="badge bg-secondary">@Model.Type</span>
                </div>

                @* Specification list. The auction-end row only appears if a date is set. *@
                <dl class="row small text-muted mb-3">
                    <dt class="col-5">Make</dt><dd class="col-7">@Model.Make</dd>
                    <dt class="col-5">Model</dt><dd class="col-7">@Model.Model</dd>
                    <dt class="col-5">Year</dt><dd class="col-7">@Model.Year</dd>
                    @if (Model.AuctionEnd.HasValue)
                    {
                        <dt class="col-5">Auction ends</dt>
                        @* dd/MM/yyyy HH:mm — explicit date format (independent of the bid culture). *@
                        <dd class="col-7">@Model.AuctionEnd.Value.ToString("dd/MM/yyyy HH:mm")</dd>
                    }
                </dl>

                @* Price summary box. *@
                <div class="bg-light rounded p-3 mb-3">
                    <div class="d-flex justify-content-between">
                        <span class="text-muted">Starting price</span>
                        <span>@Model.StartingPrice.ToString("C")</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        @* Label reads "price" before any bids, "bid" once bids exist. *@
                        <span class="text-muted">Current @(Model.HighestBid is null ? "price" : "bid")</span>
                        <span class="fw-bold text-primary fs-5">@Model.CurrentPrice.ToString("C")</span>
                    </div>
                    @if (Model.InstantBuyPrice.HasValue)
                    {
                        <div class="d-flex justify-content-between">
                            <span class="text-muted">Instant buy</span>
                            <span class="fw-semibold text-success">@Model.InstantBuyPrice.Value.ToString("C")</span>
                        </div>
                    }
                </div>

                @* The action panel has three states: closed, guest, or logged-in bidder. *@
                @if (Model.IsClosed)
                {
                    @* Closed auctions show the outcome instead of a bid form. *@
                    <div class="alert alert-secondary mb-3">
                        This auction is closed.
                        @if (Model.IsSold && Model.SoldTo is not null)
                        {
                            <strong>Sold to @Model.SoldTo.</strong>
                        }
                    </div>
                }
                else
                {
                    @if (string.IsNullOrEmpty(currentUser))
                    {
                        @* Guests are prompted to log in / register (with returnUrl back here). *@
                        <div class="alert alert-warning">
                            <strong>Log in to bid or buy.</strong>
                            <div class="small">Bidding is only available to registered users.</div>
                        </div>
                        <a asp-controller="Account" asp-action="Login"
                           asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)"
                           class="btn btn-primary w-100 mb-2">Log in to bid</a>
                        <a asp-controller="Account" asp-action="Register" class="btn btn-outline-primary w-100 mb-3">
                            Create an account
                        </a>
                    }
                    else
                    {
                        @* Logged-in users get the bid form. It POSTs to CarsController.Bid.
                           The number input is pre-filled with minNextBid and enforces it via
                           min=... (client side); the server re-checks too. *@
                        <form asp-action="Bid" method="post" class="mb-3">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <label class="form-label fw-semibold">Place a bid as @currentUser</label>
                            <div class="input-group">
                                <span class="input-group-text">€</span>
                                <input type="number" name="amount" class="form-control" step="0.01"
                                       min="@minNextBid" value="@minNextBid" required />
                                <button type="submit" class="btn btn-primary">Bid</button>
                            </div>
                            <div class="form-text">Enter more than @Model.CurrentPrice.ToString("C").</div>
                        </form>

                        @* If instant buy is available, also offer a one-click purchase. The
                           onsubmit confirm() asks the user to confirm before buying. *@
                        @if (Model.HasInstantBuy)
                        {
                            <form asp-action="Buy" method="post" class="mb-3"
                                  onsubmit="return confirm('Buy this car now for @Model.InstantBuyPrice!.Value.ToString("C")?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@Model.Id" />
                                <button type="submit" class="btn btn-success w-100">
                                    Buy now for @Model.InstantBuyPrice.GetValueOrDefault().ToString("C")
                                </button>
                            </form>
                        }
                    }
                }

                @* Favourite + share, available regardless of auction state. *@
                <div class="d-grid gap-2">
                    <partial name="_FavoriteButton" model="Model" view-data='new ViewDataDictionary(ViewData) { ["FavBtnClass"] = "w-100" }' />
                    <a asp-action="Share" asp-route-id="@Model.Id" class="btn btn-outline-secondary w-100">
                        🔗 Share this listing
                    </a>
                </div>
            </div>
        </div>

        @* ---------- Bid history ---------- *@
        <div class="card shadow-sm mt-4">
            <div class="card-header">Bid history (@Model.Bids.Count)</div>
            @if (Model.Bids.Count == 0)
            {
                <div class="card-body text-muted">No bids yet. Be the first!</div>
            }
            else
            {
                @* List the bids highest first. *@
                <ul class="list-group list-group-flush">
                   @foreach (var bid in Model.Bids.OrderByDescending(b => b.Amount))
                    {
                        <li class="list-group-item d-flex justify-content-between">
                            <span>@bid.BidderUsername</span> <span class="fw-semibold">@bid.Amount.ToString("C")</span>
                        </li>
                    }
                </ul>
            }
        </div>
    </div>
</div>

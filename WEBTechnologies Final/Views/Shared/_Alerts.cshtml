@* _Alerts.cshtml is a small partial view rendered by the layout. It shows one-time "flash"
   messages that controllers set in TempData (which survives exactly one redirect). This is
   how a success/error message from a POST action appears on the page the user is redirected
   to. The Bootstrap "alert-dismissible" markup lets the user close the banner. *@

@* "is string success" is a pattern match: it runs the block only if TempData["Success"]
   exists AND is a string, and assigns it to the local variable "success" in one step. *@
@if (TempData["Success"] is string success)
{
    <div class="alert alert-success alert-dismissible fade show mt-3" role="alert">
        @success
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@* Same idea for error messages, styled red (alert-danger). *@
@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
        @error
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
